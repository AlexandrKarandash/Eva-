# Django settings read process environment variables. Use this file as a
# template for hosting settings, Docker/Compose env_file, or local shell export.
# If you copy it to .env locally, make sure your runner loads that file.
#
# Never put real production secrets in .env.example.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
# SECRET_KEY is also accepted by settings.py, but prefer DJANGO_SECRET_KEY.
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Emerging Travel Group API
ETG_BASE_URL=https://api.worldota.net/api/b2b/v3
ETG_KEY_ID=replace-with-etg-key-id
ETG_KEY=replace-with-etg-key
ETG_WEBHOOK_SECRET=replace-with-etg-webhook-hmac-secret

# ABCEX payment gateway
ABCEX_BEARER_TOKEN=replace-with-abcex-bearer-token
ABCEX_WALLET_ID=replace-with-abcex-wallet-id

# Telegram notifications
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=replace-with-telegram-admin-chat-id

# Payment lifecycle
PAYMENT_EXPIRATION_SECONDS=1200
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# HTTPS and cookies
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000

# Enable only when every subdomain is HTTPS-only and the domain is ready
# for browser preload submission.
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
